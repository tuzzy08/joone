{
  "name": "joonecli",
  "version": "0.2.5",
  "description": "An autonomous coding agent",
  "files": [
    "dist"
  ],
  "main": "dist/cli/index.js",
  "bin": {
    "joone": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "desktop:runtime:dev": "tsx src/desktop/devServer.ts",
    "desktop:web:dev": "tsx src/desktop/webDev.ts",
    "desktop:web:build": "npx vite build --config desktop/vite.config.ts",
    "desktop:dev": "npx @tauri-apps/cli dev --config src-tauri/tauri.conf.json",
    "desktop:build": "npx @tauri-apps/cli build --config src-tauri/tauri.conf.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node ./dist/cli/postinstall.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuzzy08/joone.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/tuzzy08/joone/issues"
  },
  "homepage": "https://github.com/tuzzy08/joone#readme",
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/react-dom": "^19.2.2",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@alibaba-group/opensandbox": "^0.1.4",
    "@alibaba-group/opensandbox-code-interpreter": "^0.1.3-dev1",
    "@tauri-apps/api": "^2.8.0",
    "@clack/prompts": "^1.0.1",
    "@langchain/anthropic": "^1.3.19",
    "@langchain/core": "^1.1.27",
    "@langchain/langgraph": "^1.2.1",
    "@langchain/openai": "^1.2.11",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cross-spawn": "^7.0.6",
    "deepagents": "^1.8.1",
    "dotenv": "^17.3.1",
    "e2b": "^2.13.0",
    "express": "^5.2.1",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "langchain": "^1.2.25",
    "langsmith": "^0.5.7",
    "react": "^19.2.4",
